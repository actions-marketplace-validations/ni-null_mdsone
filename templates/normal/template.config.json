{
  "_metadata": {
    "name": "normal",
    "description": "Standard single-column documentation template with sidebar and dark/light theme toggle",
    "version": "1.1.0",
    "schema_version": "v1",
    "author": "mdsone"
  },
  "config": {
    "toc": {
      "enabled": true,
      "levels": [2, 3]
    },
    "palette": "fog-gray",
    "types": {
      "default": {
        "palette": "fog-gray",
        "code": {
          "Shiki": {
            "dark": "github-dark",
            "light": "github-light",
            "auto_detect": true
          }
        }
      },
      "fog-gray": {
        "_description": "Cool neutral gray ??clean and minimal. Default palette.",
        "palette": "fog-gray",
        "code": {
          "Shiki": {
            "dark": "github-dark",
            "light": "github-light",
            "auto_detect": true
          }
        }
      },
      "warm-cream": {
        "_description": "Warm off-white with amber-brown tones ??easy on the eyes for long reading sessions.",
        "palette": "warm-cream",
        "code": {
          "Shiki": {
            "dark": "min-dark",
            "light": "min-light",
            "auto_detect": true
          }
        }
      },
      "sage-mist": {
        "_description": "Cool green-gray tones ??natural and calm.",
        "palette": "sage-mist",
        "code": {
          "Shiki": {
            "dark": "vitesse-dark",
            "light": "min-light",
            "auto_detect": true
          }
        }
      },
      "soft-dusk": {
        "_description": "Lavender-purple tones ??distinctive and easy on the eyes.",
        "palette": "soft-dusk",
        "code": {
          "Shiki": {
            "dark": "vitesse-dark",
            "light": "vitesse-light",
            "auto_detect": true
          }
        }
      }
    }
  }
}
